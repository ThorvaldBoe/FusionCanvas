<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FusionCanvas.App.Views.MainWindow"
        Title="FusionCanvas"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        Background="#F7F8FA">
  <Grid>
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="FusionCanvas"
                 HorizontalAlignment="Center"
                 FontSize="28"
                 FontWeight="SemiBold"
                 Foreground="#1E2733" />
      <TextBlock Text="Ready when you are."
                 HorizontalAlignment="Center"
                 FontSize="13"
                 Foreground="#697586" />
    </StackPanel>
  </Grid>
</Window>
