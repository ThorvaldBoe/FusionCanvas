<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:doc="clr-namespace:FusionCanvas.App.DocumentWindow"
        xmlns:items="clr-namespace:FusionCanvas.App.Items"
        xmlns:nav="clr-namespace:FusionCanvas.App.Navigation"
        xmlns:stores="clr-namespace:FusionCanvas.App.Stores"
        xmlns:stageTools="clr-namespace:FusionCanvas.App.StageTools"
        xmlns:workspace="clr-namespace:FusionCanvas.App.Workspace"
        xmlns:views="clr-namespace:FusionCanvas.App.Views"
        xmlns:workflow="clr-namespace:FusionCanvas.Application.Workspace;assembly=FusionCanvas.Application"
        x:Class="FusionCanvas.App.Views.MainWindow"
        x:DataType="views:MainWindowViewModel"
        KeyDown="OnWindowKeyDown"
        Title="FusionCanvas"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        Background="#F7F8FA">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="300" MinWidth="240" MaxWidth="560" />
      <ColumnDefinition Width="5" />
      <ColumnDefinition Width="*" MinWidth="480" />
    </Grid.ColumnDefinitions>
    <Border Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#D9DEE7"
            BorderThickness="0,0,1,0"
            Padding="18">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top"
                    Spacing="4"
                    Margin="0,0,0,18">
          <TextBlock Text="FusionCanvas"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#1E2733" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top"
                    Spacing="4"
                    Margin="0,0,0,18">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="6">
            <TextBlock Text="Workspaces"
                       VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#243447" />
            <Button Grid.Column="1"
                    Content="⚙"
                    ToolTip.Tip="Manage workspaces"
                    Command="{Binding WorkspaceManagement.OpenWorkspaceManagementCommand}"
                    Classes="iconButton" />
          </Grid>
          <TextBlock Text="{Binding WorkspaceManagement.SelectedWorkspace.Name}"
                     FontSize="11"
                     Foreground="#687385"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top"
                    Spacing="8"
                    Margin="0,0,0,18">
          <Grid ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="6">
            <TextBlock Text="Stores"
                       VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#243447" />
            <Button Grid.Column="1"
                    Content="{Binding StoreManagement.SelectorToggleGlyph}"
                    ToolTip.Tip="{Binding StoreManagement.SelectorToggleTooltip}"
                    Command="{Binding StoreManagement.ToggleStoreSelectorCommand}"
                    Classes="iconButton" />
            <Button Grid.Column="2"
                    Content="..."
                    ToolTip.Tip="Store actions"
                    Classes="iconButton">
              <Button.Flyout>
                <MenuFlyout>
                  <MenuItem Header="Manage stores"
                            Command="{Binding StoreManagement.OpenStoreEditorCommand}" />
                  <MenuItem Header="Store assets…"
                            Click="OnContextStoreAssets" />
                </MenuFlyout>
              </Button.Flyout>
            </Button>
          </Grid>
          <Button IsVisible="{Binding StoreManagement.IsSelectorCompact}"
                  Content="{Binding StoreManagement.SelectedStore.Name}"
                  Command="{Binding StoreManagement.ToggleStoreSelectorCommand}"
                  Classes="storeSelector selected"
                  HorizontalContentAlignment="Left" />
          <StackPanel IsVisible="{Binding StoreManagement.IsSelectorExpanded}"
                      Spacing="6">
            <ScrollViewer MaxHeight="170"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding StoreManagement.SelectorStores}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="stores:StoreSelectorEntry">
                    <Button Content="{Binding Name}"
                            Command="{Binding $parent[ItemsControl].DataContext.StoreManagement.SelectStoreCommand}"
                            CommandParameter="{Binding}"
                            Classes="storeSelector"
                            Classes.selected="{Binding IsSelected}"
                            HorizontalContentAlignment="Left" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
          <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
            <Button x:Name="GroupActionsButton"
                    Grid.Column="0"
                    Content="+ New group"
                    ToolTip.Tip="Create a group in the selected niche or group"
                    Command="{Binding WorkspaceTree.BeginCreateCommand}"
                    IsEnabled="{Binding CanCreateGroup}"
                    Classes="storeSecondary" />
            <Button Grid.Column="1"
                    Content="+ New Item"
                    ToolTip.Tip="Capture an Item under the selected topic or default niche"
                    Command="{Binding WorkspaceTree.BeginCreateItemCommand}"
                    IsEnabled="{Binding CanCreateGroup}"
                    Classes="storeSecondary" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <TextBox x:Name="TreeSearchBox"
                     Text="{Binding WorkspaceTree.QueryText}"
                     PlaceholderText="Search names, ideas, notes, tags..."
                     MinHeight="34" />
            <Button Grid.Column="1"
                    Content="Clear tags"
                    IsVisible="{Binding WorkspaceTree.IsTagFilterActive}"
                    Command="{Binding WorkspaceTree.ClearTagFiltersCommand}"
                    ToolTip.Tip="Clear the active tag filter"
                    Classes="storeSecondary" />
            <ComboBox Grid.Column="2"
                      x:Name="StageFilter"
                      SelectedIndex="{Binding WorkspaceTree.StageFilterIndex}"
                      MinWidth="92"
                      MinHeight="34"
                      ToolTip.Tip="Filter Items by workflow stage"
                      Classes="statusSelector">
              <ComboBoxItem Content="All stages" />
              <ComboBoxItem Content="Idea" />
              <ComboBoxItem Content="Concept" />
              <ComboBoxItem Content="Design" />
              <ComboBoxItem Content="Listing" />
            </ComboBox>
            <ComboBox Grid.Column="3"
                      x:Name="StatusFilter"
                      SelectedIndex="{Binding WorkspaceTree.StatusFilterIndex}"
                      MinWidth="92"
                      MinHeight="34"
                      ToolTip.Tip="Filter Items by lifecycle status"
                      Classes="statusSelector">
              <ComboBoxItem Content="All statuses" />
              <ComboBoxItem Content="Draft" />
              <ComboBoxItem Content="Published" />
              <ComboBoxItem Content="Paused" />
              <ComboBoxItem Content="Rejected" />
            </ComboBox>
            <Button Grid.Column="4"
                    Content="Filters"
                    ToolTip.Tip="Filter by tag, topic scope, or archived work"
                    Command="{Binding WorkspaceTree.ClearFiltersCommand}"
                    Classes="storeSecondary"
                    Classes.active="{Binding WorkspaceTree.HasNonTextFilters}">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedRight"
                        ShowMode="Standard">
                  <Border Width="260" Padding="12">
                    <StackPanel Spacing="10">
                      <StackPanel Spacing="6">
                        <TextBlock Text="Scope" FontSize="12" FontWeight="SemiBold" Foreground="#243447" />
                        <CheckBox Content="Current topic and below"
                                  IsChecked="{Binding WorkspaceTree.ScopeToCurrentTopic}"
                                  IsEnabled="{Binding WorkspaceTree.CanScopeToCurrentTopic}"
                                  ToolTip.Tip="Limit the tree to the selected niche or group subtree" />
                        <TextBlock IsVisible="{Binding WorkspaceTree.ScopeToCurrentTopic}"
                                   Text="{Binding WorkspaceTree.ScopedTopicName, StringFormat='Current: {0}'}"
                                   FontSize="11" Foreground="#687385" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Separator Margin="0,2" />
                      <StackPanel Spacing="6">
                        <TextBlock Text="Tags" FontSize="12" FontWeight="SemiBold" Foreground="#243447" />
                        <TextBlock Text="No tags yet in this store."
                                   IsVisible="{Binding !WorkspaceTree.AvailableTags.Count}"
                                   FontSize="11" Foreground="#8B95A3" />
                        <ItemsControl ItemsSource="{Binding WorkspaceTree.AvailableTags}"
                                      IsVisible="{Binding WorkspaceTree.AvailableTags.Count}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="nav:TagFilterEntryViewModel">
                              <CheckBox Content="{Binding Name}"
                                        IsChecked="{Binding IsSelected}"
                                        Margin="0,1" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                      <Separator Margin="0,2" />
                      <CheckBox Content="Include archived"
                                IsChecked="{Binding WorkspaceTree.IncludeArchived}"
                                ToolTip.Tip="Reveal archived topics and Items with inactive treatment" />
                      <Separator Margin="0,2" />
                      <Button Content="Clear all"
                              HorizontalAlignment="Right"
                              Command="{Binding WorkspaceTree.ClearFiltersCommand}"
                              IsEnabled="{Binding WorkspaceTree.HasActiveFilters}"
                              Classes="storeSecondary" />
                    </StackPanel>
                  </Border>
                </Flyout>
              </Button.Flyout>
            </Button>
          </Grid>
          <TextBlock Text="{Binding GroupActionStatus}"
                     TextWrapping="Wrap"
                     FontSize="11"
                     Foreground="#687385" />
          <TextBlock Text="{Binding WorkspaceTree.ErrorMessage}"
                     IsVisible="{Binding WorkspaceTree.HasError}"
                     TextWrapping="Wrap"
                     FontSize="11"
                     Foreground="#B42318"
                     AutomationProperties.AutomationId="WorkspaceTreeError" />
        </StackPanel>

        <Grid>
          <TreeView x:Name="WorkspaceTreeControl"
                    ItemsSource="{Binding WorkspaceTree.Roots}"
                    Background="Transparent"
                    BorderThickness="0">
            <TreeView.ItemTemplate>
              <TreeDataTemplate x:DataType="nav:WorkspaceTreeNodeViewModel" ItemsSource="{Binding Children}">
                <Border Classes="treeRow"
                        Classes.selected="{Binding IsSelected}"
                        Classes.inactive="{Binding IsInactive}"
                        Classes.cut="{Binding IsCut}"
                        Classes.dropTarget="{Binding IsDropTarget}"
                        Classes.dropBefore="{Binding IsDropBefore}"
                        Classes.dropAfter="{Binding IsDropAfter}"
                        DragDrop.AllowDrop="True"
                        PointerPressed="OnTreeNodePointerPressed"
                        PointerMoved="OnTreeNodePointerMoved"
                        DragDrop.DragOver="OnTreeNodeDragOver"
                        DragDrop.DragLeave="OnTreeNodeDragLeave"
                        DragDrop.Drop="OnTreeNodeDrop"
                        ToolTip.Tip="Right-click for actions; Ctrl-click opens a tab; F2 renames">
                  <Border.ContextMenu>
                    <ContextMenu IsVisible="{Binding HasAssetActions}">
                      <MenuItem Header="New group (subgroup)" IsVisible="{Binding IsGroup}" Click="OnContextNewGroup" />
                      <MenuItem Header="New Item" Click="OnContextNewItem" />
                      <Separator />
              <MenuItem Header="Rename" IsVisible="{Binding HasContextActions}" Click="OnContextRename" />
              <MenuItem Header="Copy" IsVisible="{Binding HasContextActions}" Click="OnContextCopy" />
              <MenuItem Header="Cut" IsVisible="{Binding HasContextActions}" Click="OnContextCut" />
              <MenuItem Header="Paste" IsEnabled="{Binding CanPaste}" Click="OnContextPaste" />
              <MenuItem Header="Duplicate" IsVisible="{Binding IsItem}" Click="OnContextDuplicate" />
              <MenuItem Header="Assets…" Click="OnContextAssets" />
                      <Separator />
                      <MenuItem Header="Delete..." IsVisible="{Binding IsGroup}" Click="OnContextDelete" />
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Grid ColumnDefinitions="3,22,*,Auto" MinHeight="34">
                    <Border Grid.Column="0" Background="#59A17D" CornerRadius="2" />
                    <TextBlock Grid.Column="1" Text="{Binding Icon}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#526173" />
                    <Grid Grid.Column="2" Margin="4,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   IsVisible="{Binding !IsEditing}"
                                   TextTrimming="CharacterEllipsis" />
                        <ItemsControl IsVisible="{Binding HasAppliedTags}"
                                      ItemsSource="{Binding VisibleTagColorSequence}"
                                      Margin="6,0,0,0">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal" Spacing="3" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                              <Border Width="10" Height="10"
                                      CornerRadius="5"
                                      Background="{Binding Converter={x:Static nav:TagBrushConverter.Background}, FallbackValue='#F0F2F5'}"
                                      BorderBrush="{Binding Converter={x:Static nav:TagBrushConverter.Border}, FallbackValue='#D9DEE7'}"
                                      BorderThickness="1"
                                      ToolTip.Tip="Item has this tag applied" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border IsVisible="{Binding HasHiddenTags}"
                                Padding="4,0"
                                CornerRadius="6"
                                Background="#E8EDF3">
                          <TextBlock Text="{Binding HiddenTagLabel}" FontSize="10" Foreground="#526173" />
                        </Border>
                      </StackPanel>
                      <TextBox Text="{Binding DraftName}"
                               IsVisible="{Binding IsEditing}"
                               AttachedToVisualTree="OnTreeEditorAttached"
                               KeyDown="OnTreeEditorKeyDown"
                               MinHeight="28"
                               Padding="5,2" />
                    </Grid>
                    <Border Grid.Column="3" IsVisible="{Binding HasChildren}" Padding="5,1" CornerRadius="8" Background="#E8EDF3">
                      <TextBlock Text="{Binding CountLabel}" FontSize="10" Foreground="#526173" />
                    </Border>
                  </Grid>
                </Border>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
          <Border IsVisible="{Binding WorkspaceTree.HasEmptyFilterResults}"
                  Background="#F7F8FA"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        MaxWidth="220">
              <TextBlock Text="Nothing matches the current filters."
                         TextWrapping="Wrap"
                         TextAlignment="Center"
                         Foreground="#526173"
                         FontSize="12" />
              <Button Content="Clear filters"
                      HorizontalAlignment="Center"
                      Command="{Binding WorkspaceTree.ClearFiltersCommand}"
                      Classes="storeSecondary" />
            </StackPanel>
          </Border>
        </Grid>
      </DockPanel>
    </Border>

    <GridSplitter Grid.Column="1"
                  ResizeDirection="Columns"
                  Background="Transparent"
                  Cursor="SizeWestEast"
                  ToolTip.Tip="Drag to resize navigation"
                  AutomationProperties.Name="Resize navigation panel" />

    <Grid Grid.Column="2"
          RowDefinitions="Auto,Auto,*">
      <Border Grid.Row="0"
              Background="#F3F4F6"
              BorderBrush="#D9DEE7"
              BorderThickness="0,0,0,1"
              Height="40"
              Padding="6,5,6,0">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding DocumentWindow.Tabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="doc:DocumentTabViewModel">
                <Border Classes.active="{Binding IsActive}"
                        Classes="tabFrame">
                  <Grid ColumnDefinitions="*,26"
                        MinWidth="120"
                        MaxWidth="224">
                    <Button Grid.Column="0"
                            Command="{Binding $parent[ItemsControl].DataContext.RequestSelectTabCommand}"
                            CommandParameter="{Binding}"
                            Classes="tab"
                            Classes.active="{Binding IsActive}">
                      <TextBlock Text="{Binding Title}"
                                 TextTrimming="CharacterEllipsis"
                                 MaxLines="1"
                                 VerticalAlignment="Center" />
                    </Button>
                    <Button Grid.Column="1"
                            Content="×"
                            Command="{Binding $parent[ItemsControl].DataContext.RequestCloseTabCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="Close tab"
                            Classes="closeTab" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Border Grid.Row="1"
              IsVisible="{Binding WorkflowNavigator.HasActiveItem}"
              Padding="20,14"
              Background="#FFFFFF"
              BorderBrush="#D9DEE7"
              BorderThickness="0,0,0,1">
        <StackPanel Spacing="10">
          <ItemsControl ItemsSource="{Binding WorkflowNavigator.Stages}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="workflow:WorkflowStageNavigatorEntry">
                <Button Content="{Binding Label}"
                        IsEnabled="{Binding CanNavigate}"
                        Command="{Binding $parent[ItemsControl].DataContext.SelectWorkflowStageCommand}"
                        CommandParameter="{Binding Stage}"
                        Classes.current="{Binding IsCurrent}"
                        Classes.available="{Binding IsAvailable}"
                        Classes.unavailable="{Binding !IsAvailable}"
                        Classes.activeView="{Binding IsActiveView}"
                        Padding="14,8"
                        MinWidth="88" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock IsVisible="{Binding WorkflowNavigator.ShowsInactiveState}"
                     Text="{Binding WorkflowNavigator.InactiveLabel}"
                     FontSize="12"
                     Foreground="#687385" />
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              Margin="20"
              Padding="24"
              Background="#FFFFFF"
              BorderBrush="#D9DEE7"
              BorderThickness="1">
        <Grid>
          <StackPanel IsVisible="{Binding DocumentWindow.HasActiveDocument}"
                      Spacing="12">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <StackPanel Grid.Column="0" Spacing="3">
                <TextBlock Text="{Binding DocumentWindow.ActiveDetailTitle}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#1E2733" />
                <TextBlock Text="{Binding DocumentWindow.ActiveNavigationPath}"
                           FontSize="12"
                           Foreground="#687385" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         IsVisible="{Binding ItemInspector.HasState}"
                         Text="{Binding ItemInspector.StageLabel}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="#59A17D"
                         VerticalAlignment="Center" />
              <ComboBox Grid.Column="2"
                         IsVisible="{Binding HasActiveItem}"
                         ItemsSource="{Binding AvailableItemStatusOptions}"
                         SelectedItem="{Binding SelectedItemStatusOption}"
                         PlaceholderText="{Binding SelectedItemStatusLabel}"
                         MinWidth="120"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="Item lifecycle status"
                         ToolTip.Tip="Lifecycle status"
                         Classes="statusSelector">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="views:ItemStatusOptionViewModel">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <Border MinHeight="360"
                    Padding="22"
                    Background="#F7F8FA"
                    BorderBrush="#D9DEE7"
                    BorderThickness="1"
                    IsVisible="{Binding ShowStageToolHost}">
              <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      Margin="0,0,0,12">
                  <StackPanel Spacing="3">
                    <TextBlock Text="{Binding DocumentWindow.ActiveStageToolName}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#243447" />
                    <TextBlock Text="{Binding DocumentWindow.ActiveStageToolDescription}"
                               FontSize="13"
                               Foreground="#687385" />
                  </StackPanel>
                  <ItemsControl Grid.Column="1"
                                IsVisible="{Binding DocumentWindow.HasMultipleStageTools}"
                                ItemsSource="{Binding DocumentWindow.AvailableStageTools}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="doc:StageToolOptionViewModel">
                        <Button Content="{Binding DisplayName}"
                                Command="{Binding $parent[ItemsControl].DataContext.DocumentWindow.SelectStageToolCommand}"
                                CommandParameter="{Binding}"
                                Classes="toolSelector" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>

                <StackPanel Grid.Row="1"
                            Spacing="8">
                  <TextBlock Text="{Binding DocumentWindow.ActiveWorkflowStageLabel}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="#243447" />
                  <TextBlock Text="{Binding DocumentWindow.ActiveDetailViewKey}"
                             FontSize="13"
                             Foreground="#687385" />
                <Border Margin="0,10,0,0"
                        Padding="12"
                        Background="#FFFFFF"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding DocumentWindow.ActiveToolScopeLabel}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#243447" />
                    <TextBlock Text="{Binding DocumentWindow.ActiveToolScopeDescription}"
                               FontSize="12"
                               Foreground="#687385" />
                    <TextBlock IsVisible="{Binding !DocumentWindow.CanRunActiveTool}"
                               Text="{Binding DocumentWindow.ActiveToolUnavailableMessage}"
                               FontSize="12"
                               Foreground="#9A4B43" />
                    <TextBlock IsVisible="{Binding !DocumentWindow.CanRunActiveTool}"
                               Text="{Binding DocumentWindow.ActiveStageToolUnavailableMessage}"
                               FontSize="12"
                               Foreground="#9A4B43" />
                  </StackPanel>
                </Border>
                </StackPanel>
              </Grid>
            </Border>

            <Border IsVisible="{Binding ItemInspector.HasState}"
                    MinHeight="360"
                    Padding="22"
                    Background="#F7F8FA"
                    BorderBrush="#D9DEE7"
                    BorderThickness="1">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                  <TextBlock IsVisible="{Binding ItemInspector.IsReadOnly}"
                             Text="{Binding ItemInspector.InactiveNotice}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="#9A4B43" />
                  <TextBlock Text="{Binding ItemInspector.DisplayPath}"
                             FontSize="12"
                             Foreground="#687385" />

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Overview"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <StackPanel Spacing="6">
                        <TextBlock Text="Working title"
                                   FontSize="11"
                                   Foreground="#687385" />
                        <TextBox Text="{Binding ItemInspector.Title}"
                                 IsReadOnly="{Binding !ItemInspector.CanEditShared}"
                                 MinHeight="32"
                                 PlaceholderText="Optional working title"
                                 AutomationProperties.Name="Item working title" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6"
                          IsVisible="{Binding ShowsIdeaStageTool}"
                          Classes.emphasized="{Binding ItemInspector.EmphasizesIdea}">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Idea"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <TextBox Text="{Binding ItemInspector.Idea}"
                               IsReadOnly="{Binding !ItemInspector.CanEditStage}"
                               AcceptsReturn="True"
                               MinHeight="64"
                               PlaceholderText="What is the original product idea?"
                               AutomationProperties.Name="Original idea" />
                      <TextBlock IsVisible="{Binding !ItemInspector.CanEditStage}"
                                 Text="{Binding ItemInspector.StageReadOnlyReason}"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="#9A4B43" />
                    </StackPanel>
                  </Border>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6"
                          IsVisible="{Binding ShowsConceptStageTool}"
                          Classes.emphasized="{Binding ItemInspector.EmphasizesConcept}">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Concept"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <TextBlock Text="Concept idea"
                                 FontSize="11"
                                 Foreground="#687385" />
                      <TextBox Text="{Binding ItemInspector.ConceptIdea}"
                               IsReadOnly="{Binding !ItemInspector.CanEditStage}"
                               AcceptsReturn="True"
                               MinHeight="64"
                               PlaceholderText="Refine the original idea"
                               AutomationProperties.Name="Concept idea" />
                      <TextBlock Text="Phrase"
                                 FontSize="11"
                                 Foreground="#687385" />
                      <TextBox Text="{Binding ItemInspector.Phrase}"
                               IsReadOnly="{Binding !ItemInspector.CanEditStage}"
                               MinHeight="32"
                               PlaceholderText="Single-line on-product phrase"
                               AutomationProperties.Name="Concept phrase" />
                      <TextBlock Text="Graphic direction"
                                 FontSize="11"
                                 Foreground="#687385" />
                      <TextBox Text="{Binding ItemInspector.GraphicDirection}"
                               IsReadOnly="{Binding !ItemInspector.CanEditStage}"
                               AcceptsReturn="True"
                               MinHeight="64"
                               PlaceholderText="Visual direction supporting this concept"
                               AutomationProperties.Name="Graphics description" />
                      <TextBlock IsVisible="{Binding !ItemInspector.CanEditStage}"
                                 Text="{Binding ItemInspector.StageReadOnlyReason}"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="#9A4B43" />
                    </StackPanel>
                  </Border>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Notes"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <TextBox Text="{Binding ItemInspector.Notes}"
                               IsReadOnly="{Binding !ItemInspector.CanEditShared}"
                               AcceptsReturn="True"
                               MinHeight="80"
                               PlaceholderText="Plain-text notes"
                               AutomationProperties.Name="Item notes" />
                    </StackPanel>
                  </Border>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Tags"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <ItemsControl ItemsSource="{Binding ItemInspector.TagDraft}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="x:String">
                            <Border Padding="8,3"
                                    CornerRadius="10"
                                    Background="#EEF6FF"
                                    BorderBrush="#B9D7F2"
                                    BorderThickness="1"
                                    Margin="0,0,6,6">
                              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Text="{Binding}"
                                           FontSize="12"
                                           Foreground="#204466"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="×"
                                        Padding="0"
                                        Width="18"
                                        Height="18"
                                        FontSize="13"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#204466"
                                        ToolTip.Tip="Remove tag"
                                        Command="{Binding $parent[ItemsControl].DataContext.ItemInspector.RemoveTagCommand}"
                                        CommandParameter="{Binding}" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock IsVisible="{Binding !ItemInspector.HasTags}"
                                 Text="No tags yet."
                                 FontSize="12"
                                 Foreground="#7C8797" />
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <TextBox Text="{Binding ItemInspector.TagInput}"
                                 IsEnabled="{Binding ItemInspector.CanEditShared}"
                                 MinHeight="32"
                                 PlaceholderText="Add a tag" />
                        <Button Grid.Column="1"
                                Content="Add"
                                IsEnabled="{Binding ItemInspector.CanEditShared}"
                                Command="{Binding ItemInspector.AddTagCommand}"
                                Classes="storeSecondary" />
                      </Grid>
                    </StackPanel>
                  </Border>

                  <Border IsVisible="{Binding ShowsDesignStageTool}"
                          Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6"
                          Classes.emphasized="{Binding ItemInspector.EmphasizesDesign}">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Design"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <TextBlock Text="Managed PNG Design files"
                                 FontSize="12"
                                 Foreground="#687385" />
                      <ListBox ItemsSource="{Binding DesignTool.Files}"
                               SelectedItem="{Binding DesignTool.SelectedFile}"
                               MinHeight="72"
                               AutomationProperties.Name="Design files">
                        <ListBox.ItemTemplate>
                          <DataTemplate x:DataType="stageTools:DesignFileViewModel">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Text="{Binding Name}" />
                              <TextBlock Grid.Column="1"
                                         IsVisible="{Binding IsMissing}"
                                         Text="Missing"
                                         Foreground="#9A4B43" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <TextBlock Text="{Binding DesignTool.EmptyState}"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="#7C8797" />
                      <TextBlock IsVisible="{Binding DesignTool.IsReadOnly}"
                                 Text="{Binding DesignTool.ReadOnlyReason}"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="#9A4B43" />
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import PNG…"
                                IsEnabled="{Binding !DesignTool.IsReadOnly}"
                                Click="OnImportDesignFiles"
                                ToolTip.Tip="Import one or more PNG Design files"
                                AutomationProperties.Name="Import PNG Design files"
                                Classes="storeSecondary" />
                        <Button Content="Preview"
                                Click="OnPreviewDesignFile"
                                ToolTip.Tip="Preview the selected managed PNG"
                                Classes="storeSecondary" />
                        <Button Content="Export copy…"
                                Click="OnExportDesignFile"
                                ToolTip.Tip="Export an independent copy"
                                Classes="storeSecondary" />
                        <Button Content="Remove…"
                                IsEnabled="{Binding !DesignTool.IsReadOnly}"
                                Click="OnRequestRemoveDesignFile"
                                ToolTip.Tip="Remove the selected Design file"
                                Classes="storeSecondary" />
                      </StackPanel>
                      <Border IsVisible="{Binding IsDesignRemoveConfirmationVisible}"
                              Padding="10"
                              Background="#FEECEB"
                              CornerRadius="6">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Remove this Design file and its managed copy permanently?"
                                     TextWrapping="Wrap" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Remove"
                                    Command="{Binding ConfirmDesignRemoveCommand}"
                                    Classes="storeAction" />
                            <Button Content="Cancel"
                                    Command="{Binding CancelDesignRemoveCommand}"
                                    Classes="storeSecondary" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                      <TextBlock IsVisible="{Binding DesignTool.ErrorMessage}"
                                 Text="{Binding DesignTool.ErrorMessage}"
                                 TextWrapping="Wrap"
                                 Foreground="#9A4B43" />
                    </StackPanel>
                  </Border>

                  <Border IsVisible="{Binding ShowsListingStageTool}"
                          Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="8">
                      <TextBlock Text="Listing"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <TextBlock Text="{Binding ListingTool.StatusSummary}"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="#687385" />
                      <TextBlock Text="Marketplace fields, mockups, and external publishing are outside this basic local workflow."
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="#687385" />
                    </StackPanel>
                  </Border>

                  <StackPanel Orientation="Horizontal"
                              Spacing="8"
                              HorizontalAlignment="Left">
                    <Button x:Name="SaveItemButton"
                            Content="Save"
                            IsEnabled="{Binding ItemInspector.HasUnsavedChanges}"
                            Command="{Binding ItemInspector.SaveCommand}"
                            ToolTip.Tip="Save working title, current-stage text, and Notes"
                            AutomationProperties.Name="Save Item changes"
                            Classes="storeAction" />
                    <Button Content="Discard"
                            IsEnabled="{Binding ItemInspector.HasUnsavedChanges}"
                            Command="{Binding ItemInspector.DiscardCommand}"
                            ToolTip.Tip="Discard unsaved Item text changes"
                            Classes="storeSecondary" />
                  </StackPanel>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Related assets"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <ItemsControl ItemsSource="{Binding ItemInspector.Assets}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="workflow:ItemInspectorAssetEntry">
                            <StackPanel Margin="0,0,0,4" Spacing="2">
                              <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#243447" />
                              <TextBlock Text="{Binding Kind}" FontSize="11" Foreground="#687385" />
                              <TextBlock IsVisible="{Binding IsMissing}"
                                         Text="Missing file"
                                         FontSize="11"
                                         Foreground="#9A4B43" />
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock IsVisible="{Binding !ItemInspector.HasAssets}"
                                 Text="No assets attached yet."
                                 FontSize="12"
                                 Foreground="#7C8797" />
                    </StackPanel>
                  </Border>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Lifecycle"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8"
                                  HorizontalAlignment="Left">
                        <Button Content="Archive"
                                IsVisible="{Binding ItemInspector.CanArchive}"
                                Command="{Binding RequestArchiveItemCommand}"
                                ToolTip.Tip="Archive this Item without deleting it"
                                Classes="storeSecondary" />
                        <Button Content="Restore"
                                IsVisible="{Binding ItemInspector.CanRestore}"
                                Command="{Binding RestoreItemCommand}"
                                ToolTip.Tip="Restore this Item to its preserved topic"
                                Classes="storeSecondary" />
                        <Button Content="Delete…"
                                IsVisible="{Binding ItemInspector.HasState}"
                                IsEnabled="{Binding ItemInspector.CanDelete}"
                                Command="{Binding RequestDeleteItemCommand}"
                                ToolTip.Tip="Permanently delete this Item"
                                Classes="storeSecondary" />
                      </StackPanel>
                      <Border IsVisible="{Binding ItemInspector.ArchiveConfirmationVisible}"
                              Padding="10"
                              Background="#FFF4E5"
                              CornerRadius="6">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Archive this Item? It leaves active navigation but stays recoverable."
                                     TextWrapping="Wrap"
                                     FontSize="12"
                                     Foreground="#243447" />
                          <StackPanel Orientation="Horizontal"
                                      Spacing="8"
                                      HorizontalAlignment="Left">
                            <Button Content="Archive"
                                    Command="{Binding ItemInspector.ConfirmArchiveCommand}"
                                    Classes="storeAction" />
                            <Button Content="Cancel"
                                    Command="{Binding ItemInspector.CancelArchiveCommand}"
                                    Classes="storeSecondary" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                      <Border IsVisible="{Binding ItemInspector.DeleteConfirmationVisible}"
                              Padding="10"
                              Background="#FEECEB"
                              CornerRadius="6">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Permanently delete this Item? Connected creative records will block deletion."
                                     TextWrapping="Wrap"
                                     FontSize="12"
                                     Foreground="#243447" />
                          <StackPanel Orientation="Horizontal"
                                      Spacing="8"
                                      HorizontalAlignment="Left">
                            <Button Content="Delete permanently"
                                    Command="{Binding ItemInspector.ConfirmDeleteCommand}"
                                    Classes="storeAction" />
                            <Button Content="Cancel"
                                    Command="{Binding ItemInspector.CancelDeleteCommand}"
                                    Classes="storeSecondary" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>

                  <TextBlock IsVisible="{Binding ItemInspector.HasError}"
                             Text="{Binding ItemInspector.ErrorMessage}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="#9A4B43" />
                </StackPanel>
              </ScrollViewer>
            </Border>

            <Border IsVisible="{Binding IsUnsavedChangesPromptVisible}"
                    Padding="12"
                    Background="#FFF4E5"
                    BorderBrush="#E5B86A"
                    BorderThickness="1"
                    CornerRadius="6">
              <StackPanel Spacing="8">
                <TextBlock Text="Save Item changes?"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding UnsavedChangesPromptMessage}"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Save"
                          Command="{Binding SaveAndContinueCommand}"
                          Classes="storeAction" />
                  <Button Content="Discard"
                          Command="{Binding DiscardAndContinueCommand}"
                          Classes="storeSecondary" />
                  <Button x:Name="CancelUnsavedTransitionButton"
                          Content="Cancel"
                          Command="{Binding CancelPendingTransitionCommand}"
                          Classes="storeSecondary" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsStatusConfirmationVisible}"
                    Padding="12"
                    Background="#FFF4E5"
                    BorderBrush="#E5B86A"
                    BorderThickness="1"
                    CornerRadius="6">
              <StackPanel Spacing="8">
                <TextBlock Text="Confirm lifecycle change"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusConfirmationMessage}"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Confirm"
                          Command="{Binding ConfirmStatusChangeCommand}"
                          Classes="storeAction" />
                  <Button x:Name="CancelStatusChangeButton"
                          Content="Cancel"
                          Command="{Binding CancelStatusChangeCommand}"
                          Classes="storeSecondary" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border IsVisible="{Binding GroupDetails.HasState}"
                    MinHeight="360"
                    Padding="22"
                    Background="#F7F8FA"
                    BorderBrush="#D9DEE7"
                    BorderThickness="1">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                  <TextBlock IsVisible="{Binding GroupDetails.IsReadOnly}"
                             Text="{Binding GroupDetails.InactiveNotice}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="#9A4B43" />
                  <TextBlock Text="{Binding GroupDetails.DisplayPath}"
                             FontSize="12"
                             Foreground="#687385" />

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Group details"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <StackPanel Spacing="6">
                        <TextBlock Text="Group name"
                                   FontSize="11"
                                   Foreground="#687385" />
                        <TextBox Text="{Binding GroupDetails.Name}"
                                 IsReadOnly="{Binding !GroupDetails.CanEdit}"
                                 MinHeight="32"
                                 PlaceholderText="Group name"
                                 LostFocus="OnDetailsFieldLostFocus" />
                        <TextBlock Text="Description"
                                   FontSize="11"
                                   Foreground="#687385" />
                        <TextBox Text="{Binding GroupDetails.Description}"
                                 IsReadOnly="{Binding !GroupDetails.CanEdit}"
                                 MinHeight="32"
                                 PlaceholderText="Description or purpose"
                                 LostFocus="OnDetailsFieldLostFocus" />
                        <TextBlock Text="Notes"
                                   FontSize="11"
                                   Foreground="#687385" />
                        <TextBox Text="{Binding GroupDetails.Notes}"
                                 IsReadOnly="{Binding !GroupDetails.CanEdit}"
                                 AcceptsReturn="True"
                                 MinHeight="80"
                                 PlaceholderText="Notes and working context"
                                 LostFocus="OnDetailsFieldLostFocus" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Location"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <ComboBox ItemsSource="{Binding GroupDetails.Destinations}"
                                SelectedItem="{Binding GroupDetails.SelectedDestination}"
                                IsEnabled="{Binding GroupDetails.CanEdit}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="workflow:GroupDestination">
                            <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8"
                                  HorizontalAlignment="Left">
                        <Button Content="Move"
                                IsEnabled="{Binding GroupDetails.CanMove}"
                                Command="{Binding GroupDetails.MoveCommand}"
                                ToolTip.Tip="Move this group and its contents to the selected location"
                                Classes="storeSecondary" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Padding="14"
                          Background="#FFFFFF"
                          BorderBrush="#D9DEE7"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Spacing="10">
                      <TextBlock Text="Lifecycle"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#243447" />
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8"
                                  HorizontalAlignment="Left">
                        <Button Content="Archive"
                                IsVisible="{Binding GroupDetails.CanArchive}"
                                Command="{Binding GroupDetails.RequestArchiveCommand}"
                                ToolTip.Tip="Archive this group and its subtree without deleting them"
                                Classes="storeSecondary" />
                        <Button Content="Restore"
                                IsVisible="{Binding GroupDetails.CanRestore}"
                                Command="{Binding GroupDetails.RestoreCommand}"
                                ToolTip.Tip="Restore this group and its subtree"
                                Classes="storeSecondary" />
                      </StackPanel>
                      <Border IsVisible="{Binding GroupDetails.ArchiveConfirmationVisible}"
                              Padding="10"
                              Background="#FFF4E5"
                              CornerRadius="6">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Archive this group? The group and its subtree leave active navigation, but all child work and context remain preserved."
                                     TextWrapping="Wrap"
                                     FontSize="12"
                                     Foreground="#243447" />
                          <StackPanel Orientation="Horizontal"
                                      Spacing="8"
                                      HorizontalAlignment="Left">
                            <Button Content="Archive"
                                    Command="{Binding GroupDetails.ConfirmArchiveCommand}"
                                    Classes="storeAction" />
                            <Button Content="Cancel"
                                    Command="{Binding GroupDetails.CancelArchiveCommand}"
                                    Classes="storeSecondary" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>

                  <TextBlock IsVisible="{Binding GroupDetails.HasError}"
                             Text="{Binding GroupDetails.ErrorMessage}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="#9A4B43" />
                </StackPanel>
              </ScrollViewer>
            </Border>

            <Grid ColumnDefinitions="*,Auto,Auto"
                  IsVisible="{Binding HasActiveItem}"
                  Margin="0,4,0,0">
              <TextBlock Grid.Column="0"
                         Text="{Binding StageMoveError}"
                         IsVisible="{Binding StageMoveError}"
                         FontSize="12"
                         Foreground="#9A4B43"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap" />
              <Button Grid.Column="1"
                      Content="{Binding StageMoveBackLabel}"
                      IsEnabled="{Binding CanMoveStageBack}"
                      Command="{Binding MoveStageBackCommand}"
                      Classes="stageMove"
                      Margin="0,0,6,0" />
              <Button Grid.Column="2"
                      Content="{Binding StageMoveForwardLabel}"
                      IsEnabled="{Binding CanMoveStageForward}"
                      Command="{Binding MoveStageForwardCommand}"
                      Classes="stageMove" />
            </Grid>
          </StackPanel>

          <StackPanel IsVisible="{Binding !DocumentWindow.HasActiveDocument}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="8">
            <TextBlock Text="{Binding DocumentWindow.EmptyStateTitle}"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#1E2733" />
            <TextBlock Text="{Binding DocumentWindow.EmptyStateMessage}"
                       HorizontalAlignment="Center"
                       FontSize="13"
                       Foreground="#697586" />
          </StackPanel>

          <Border IsVisible="{Binding ShowSelectionSummary}"
                  Background="#FFFFFF"
                  Padding="4">
            <StackPanel Spacing="14">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding WorkspaceTree.InspectorKind}" FontSize="12" FontWeight="SemiBold" Foreground="#59A17D" />
                <TextBlock Text="{Binding WorkspaceTree.InspectorTitle}" FontSize="26" FontWeight="SemiBold" Foreground="#1E2733" />
                <TextBlock Text="{Binding WorkspaceTree.InspectorPath}" FontSize="12" Foreground="#687385" />
              </StackPanel>
              <Border Padding="18" Background="#F7F8FA" BorderBrush="#D9DEE7" BorderThickness="1">
                <StackPanel Spacing="8">
                  <TextBlock Text="Properties" FontSize="14" FontWeight="SemiBold" Foreground="#243447" />
                  <TextBlock Text="{Binding WorkspaceTree.InspectorDescription}" TextWrapping="Wrap" Foreground="#687385" />
                  <TextBlock Text="Selection updates this inspector without opening a tab. Ctrl-click the tree node to keep it in a tab."
                             TextWrapping="Wrap" FontSize="12" Foreground="#7C8797" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>
    <Border Grid.ColumnSpan="2"
            IsVisible="{Binding WorkspaceManagement.ShouldShowNoWorkspaceState}"
            Background="#99000000">
      <Border Width="420"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="20"
              Background="#FFFFFF"
              BorderBrush="#D9DEE7"
              BorderThickness="1">
        <StackPanel Spacing="12">
          <TextBlock Text="Create your first workspace?"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#1E2733" />
          <TextBlock Text="FusionCanvas needs a workspace before stores can be organized."
                     TextWrapping="Wrap"
                     FontSize="13"
                     Foreground="#687385" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="Create workspace"
                    Command="{Binding WorkspaceManagement.CreateWorkspaceCommand}"
                    Classes="storeAction fixedDialog" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
    <Border Grid.ColumnSpan="2"
            IsVisible="{Binding ShouldShowFirstStorePrompt}"
            Background="#99000000">
      <Border Width="420"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="20"
              Background="#FFFFFF"
              BorderBrush="#D9DEE7"
              BorderThickness="1">
        <StackPanel Spacing="12">
          <TextBlock Text="Create your first store?"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#1E2733" />
          <TextBlock Text="FusionCanvas needs a store before workspace content can be organized."
                     TextWrapping="Wrap"
                     FontSize="13"
                     Foreground="#687385" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="Create store"
                    Command="{Binding StoreManagement.AcceptFirstStorePromptCommand}"
                    Classes="storeAction fixedDialog" />
            <Button Content="Not now"
                    Command="{Binding StoreManagement.DeclineFirstStorePromptCommand}"
                    Classes="storeSecondary fixedDialog" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
  <Window.Styles>
    <Style Selector="TreeViewItem" x:DataType="nav:WorkspaceTreeNodeViewModel">
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,1" />
    </Style>
    <Style Selector="Border.treeRow">
      <Setter Property="Padding" Value="5,2" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.treeRow:pointerover">
      <Setter Property="Background" Value="#F0F3F7" />
    </Style>
    <Style Selector="Border.treeRow.selected">
      <Setter Property="Background" Value="#E2EAF2" />
    </Style>
    <Style Selector="Border.treeRow.inactive">
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Border.treeRow.inactive:pointerover">
      <Setter Property="Opacity" Value="0.7" />
    </Style>
    <Style Selector="Border.treeRow.cut">
      <Setter Property="Opacity" Value="0.48" />
    </Style>
    <Style Selector="Border.treeRow.inactive">
      <Setter Property="Opacity" Value="0.6" />
    </Style>
    <Style Selector="Border.treeRow.dropTarget">
      <Setter Property="Background" Value="#DDF1E7" />
      <Setter Property="BorderBrush" Value="#59A17D" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.treeRow.dropBefore">
      <Setter Property="BorderBrush" Value="#3C8C69" />
      <Setter Property="BorderThickness" Value="0,2,0,0" />
    </Style>
    <Style Selector="Border.treeRow.dropAfter">
      <Setter Property="BorderBrush" Value="#3C8C69" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>
    <Style Selector="Button.navigation">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Background" Value="#F7F8FA" />
      <Setter Property="Foreground" Value="#243447" />
      <Setter Property="BorderBrush" Value="#E1E5EA" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.storeSelector">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#EEF6FF" />
      <Setter Property="Foreground" Value="#204466" />
      <Setter Property="BorderBrush" Value="#B9D7F2" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.storeSelector.selected">
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#243447" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.storeAction">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#243447" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.fixedDialog">
      <Setter Property="Width" Value="116" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.storeSecondary">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#425066" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.storeSecondary.active">
      <Setter Property="Background" Value="#EEF6FF" />
      <Setter Property="Foreground" Value="#204466" />
      <Setter Property="BorderBrush" Value="#B9D7F2" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.iconButton">
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#425066" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.tabFrame">
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="5,5,0,0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.tabFrame.active">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D3D8E0" />
      <Setter Property="BorderThickness" Value="1,1,1,0" />
    </Style>
    <Style Selector="Button.tab">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="10,0,4,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#687385" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.tab.active">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#1E2733" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.closeTab">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Margin" Value="0,6,4,6" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#687385" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.closeTab:pointerover">
      <Setter Property="Background" Value="#E7E9ED" />
      <Setter Property="Foreground" Value="#1E2733" />
    </Style>
    <Style Selector="Button.available">
      <Setter Property="Background" Value="#EEF6FF" />
      <Setter Property="Foreground" Value="#204466" />
      <Setter Property="BorderBrush" Value="#B9D7F2" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.current">
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#243447" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.unavailable">
      <Setter Property="Background" Value="#F1F3F6" />
      <Setter Property="Foreground" Value="#8B95A3" />
      <Setter Property="BorderBrush" Value="#E1E5EA" />
    </Style>
    <Style Selector="Button.activeView:not(.current)">
      <Setter Property="BorderBrush" Value="#3C8C69" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.stageMove">
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="MinWidth" Value="120" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#243447" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.stageMove:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="ComboBox.statusSelector">
      <Setter Property="MinWidth" Value="120" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.toolSelector">
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#243447" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.emphasized">
      <Setter Property="BorderBrush" Value="#59A17D" />
      <Setter Property="BorderThickness" Value="1.5" />
    </Style>
  </Window.Styles>
</Window>
