<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:doc="clr-namespace:FusionCanvas.App.DocumentWindow"
        xmlns:views="clr-namespace:FusionCanvas.App.Views"
        xmlns:workflow="clr-namespace:FusionCanvas.Application.Workspace;assembly=FusionCanvas.Application"
        x:Class="FusionCanvas.App.Views.MainWindow"
        x:DataType="views:MainWindowViewModel"
        Title="FusionCanvas"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        Background="#F7F8FA">
  <Grid ColumnDefinitions="280,*">
    <Border Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#D9DEE7"
            BorderThickness="0,0,1,0"
            Padding="18">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top"
                    Spacing="4"
                    Margin="0,0,0,18">
          <TextBlock Text="FusionCanvas"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#1E2733" />
          <TextBlock Text="Workspace"
                     FontSize="12"
                     Foreground="#687385" />
        </StackPanel>

        <ItemsControl ItemsSource="{Binding NavigationContexts}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="views:NavigationDocumentContext">
              <Button Content="{Binding Label}"
                      Command="{Binding $parent[ItemsControl].DataContext.OpenNavigationContextCommand}"
                      CommandParameter="{Binding}"
                      Classes="navigation"
                      HorizontalContentAlignment="Left" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1"
          RowDefinitions="Auto,Auto,*">
      <Border Grid.Row="0"
              Background="#FFFFFF"
              BorderBrush="#D9DEE7"
              BorderThickness="0,0,0,1"
              MinHeight="48">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding DocumentWindow.Tabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="doc:DocumentTabViewModel">
                <Border Classes.active="{Binding IsActive}"
                        Classes="tabFrame">
                  <Grid ColumnDefinitions="*,Auto"
                        MinWidth="152"
                        MaxWidth="240">
                    <Button Grid.Column="0"
                            Content="{Binding Title}"
                            Command="{Binding $parent[ItemsControl].DataContext.DocumentWindow.SelectTabCommand}"
                            CommandParameter="{Binding}"
                            Classes="tab"
                            Classes.active="{Binding IsActive}" />
                    <Button Grid.Column="1"
                            Content="X"
                            Command="{Binding $parent[ItemsControl].DataContext.DocumentWindow.CloseTabCommand}"
                            CommandParameter="{Binding}"
                            Classes="closeTab" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Border Grid.Row="1"
              IsVisible="{Binding WorkflowNavigator.HasActiveItem}"
              Padding="20,14"
              Background="#FFFFFF"
              BorderBrush="#D9DEE7"
              BorderThickness="0,0,0,1">
        <StackPanel Spacing="10">
          <ItemsControl ItemsSource="{Binding WorkflowNavigator.Stages}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="workflow:WorkflowStageNavigatorEntry">
                <Button Content="{Binding Label}"
                        IsEnabled="{Binding CanNavigate}"
                        Command="{Binding $parent[ItemsControl].DataContext.SelectWorkflowStageCommand}"
                        CommandParameter="{Binding Stage}"
                        Classes.current="{Binding IsCurrent}"
                        Classes.available="{Binding IsAvailable}"
                        Classes.unavailable="{Binding !IsAvailable}"
                        Padding="14,8"
                        MinWidth="88" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock IsVisible="{Binding WorkflowNavigator.ShowsInactiveState}"
                     Text="{Binding WorkflowNavigator.InactiveLabel}"
                     FontSize="12"
                     Foreground="#687385" />
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              Margin="20"
              Padding="24"
              Background="#FFFFFF"
              BorderBrush="#D9DEE7"
              BorderThickness="1">
        <Grid>
          <StackPanel IsVisible="{Binding DocumentWindow.HasActiveDocument}"
                      Spacing="12">
            <TextBlock Text="{Binding DocumentWindow.ActiveDetailTitle}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1E2733" />
            <TextBlock Text="{Binding DocumentWindow.ActiveNavigationPath}"
                       FontSize="12"
                       Foreground="#687385" />
            <Border MinHeight="360"
                    Padding="22"
                    Background="#F7F8FA"
                    BorderBrush="#D9DEE7"
                    BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding DocumentWindow.ActiveWorkflowStageLabel}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#243447" />
                <TextBlock Text="{Binding DocumentWindow.ActiveDetailViewKey}"
                           FontSize="13"
                           Foreground="#687385" />
                <Border Margin="0,10,0,0"
                        Padding="12"
                        Background="#FFFFFF"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding DocumentWindow.ActiveToolScopeLabel}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#243447" />
                    <TextBlock Text="{Binding DocumentWindow.ActiveToolScopeDescription}"
                               FontSize="12"
                               Foreground="#687385" />
                    <TextBlock IsVisible="{Binding !DocumentWindow.CanRunActiveTool}"
                               Text="{Binding DocumentWindow.ActiveToolUnavailableMessage}"
                               FontSize="12"
                               Foreground="#9A4B43" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel IsVisible="{Binding !DocumentWindow.HasActiveDocument}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="8">
            <TextBlock Text="{Binding DocumentWindow.EmptyStateTitle}"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#1E2733" />
            <TextBlock Text="{Binding DocumentWindow.EmptyStateMessage}"
                       HorizontalAlignment="Center"
                       FontSize="13"
                       Foreground="#697586" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
  <Window.Styles>
    <Style Selector="Button.navigation">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Background" Value="#F7F8FA" />
      <Setter Property="Foreground" Value="#243447" />
      <Setter Property="BorderBrush" Value="#E1E5EA" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.tabFrame">
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>
    <Style Selector="Border.tabFrame.active">
      <Setter Property="Background" Value="#F7F8FA" />
    </Style>
    <Style Selector="Button.tab">
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#425066" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.tab.active">
      <Setter Property="Background" Value="#F7F8FA" />
      <Setter Property="Foreground" Value="#1E2733" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.closeTab">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Margin" Value="0,8,8,8" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#687385" />
      <Setter Property="BorderBrush" Value="#E1E5EA" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.available">
      <Setter Property="Background" Value="#EEF6FF" />
      <Setter Property="Foreground" Value="#204466" />
      <Setter Property="BorderBrush" Value="#B9D7F2" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.current">
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#243447" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.unavailable">
      <Setter Property="Background" Value="#F1F3F6" />
      <Setter Property="Foreground" Value="#8B95A3" />
      <Setter Property="BorderBrush" Value="#E1E5EA" />
    </Style>
  </Window.Styles>
</Window>
