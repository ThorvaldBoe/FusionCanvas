<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assets="using:FusionCanvas.App.Assets"
        xmlns:workflow="clr-namespace:FusionCanvas.Application.Workspace;assembly=FusionCanvas.Application"
        x:Class="FusionCanvas.App.Assets.AssetsWindow"
        x:DataType="assets:AssetsViewModel"
        Title="Assets"
        Width="780"
        Height="620"
        MinWidth="560"
        MinHeight="440"
        Background="#F7F8FA">
  <Grid RowDefinitions="Auto,*,Auto" Margin="20">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
      <TextBlock Text="{Binding ContextKindLabel}" FontSize="12" FontWeight="SemiBold" Foreground="#59A17D" />
      <TextBlock Text="{Binding ContextTitle}" FontSize="22" FontWeight="SemiBold" Foreground="#1E2733" />
      <TextBlock Text="Import files to attach them to this context and preserve their managed workspace copy." TextWrapping="Wrap" FontSize="11" Foreground="#687385" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="0,0,0,14">
      <StackPanel Spacing="10">
        <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextWrapping="Wrap" FontSize="12" Foreground="#9A4B43" />

        <Border IsVisible="{Binding IsEmpty}"
                Padding="18"
                Background="#F7F8FA"
                BorderBrush="#D9DEE7"
                BorderThickness="1"
                CornerRadius="6">
          <StackPanel Spacing="6">
            <TextBlock Text="No assets yet" FontSize="14" FontWeight="SemiBold" Foreground="#243447" />
            <TextBlock Text="Import a design source, export, mockup, reference, texture, brush, or font to attach it here." TextWrapping="Wrap" FontSize="12" Foreground="#687385" />
          </StackPanel>
        </Border>

        <ItemsControl ItemsSource="{Binding Assets}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="assets:AssetRowViewModel">
              <Border Padding="12" Background="#FFFFFF" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                <Grid ColumnDefinitions="*,180,Auto" ColumnSpacing="10">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#1E2733" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding ManagedFileName}" FontSize="11" Foreground="#687385" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Missing managed file" IsVisible="{Binding IsMissing}" FontSize="11" Foreground="#9A4B43" />
                    <TextBlock Text="{Binding ContextLabel}" IsVisible="{Binding ContextLabel, Converter={x:Static ObjectConverters.IsNotNull}}" FontSize="11" Foreground="#59A17D" />
                  </StackPanel>
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding Parent.AvailablePurposes}"
                            SelectedItem="{Binding SelectedPurpose}"
                            IsEnabled="{Binding !Parent.IsBusy}"
                            ToolTip.Tip="Asset purpose"
                            MinHeight="32" />
                  <Button Grid.Column="2"
                          Content="Remove…"
                          Command="{Binding $parent[ItemsControl].DataContext.RequestRemoveCommand}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding !Parent.IsBusy}"
                          ToolTip.Tip="Permanently remove asset and managed file"
                          Classes="danger" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border IsVisible="{Binding HasImportPending}"
                Padding="14"
                Background="#EEF6FF"
                BorderBrush="#B9D7F2"
                BorderThickness="1"
                CornerRadius="6">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Confirm import" FontSize="13" FontWeight="SemiBold" Foreground="#204466" />
                <TextBlock Text="{Binding PendingImportFileName}" FontSize="11" Foreground="#687385" TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding AvailablePurposes}"
                        SelectedItem="{Binding PendingImportPurpose}"
                        IsEnabled="{Binding CanConfirmImport}"
                        ToolTip.Tip="Pre-selected from file extension"
                        MinWidth="160"
                        MinHeight="32" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Confirm import" Command="{Binding ConfirmImportCommand}" IsEnabled="{Binding CanConfirmImport}" Classes="primary" />
              <Button Content="Cancel" Command="{Binding CancelImportCommand}" Classes="secondary" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border IsVisible="{Binding RemovalConfirmationVisible}"
                Padding="14"
                Background="#FEECEB"
                BorderBrush="#E3B4B0"
                BorderThickness="1"
                CornerRadius="6">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding RemovalPromptMessage}" TextWrapping="Wrap" FontSize="13" Foreground="#9A4B43" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Remove permanently" Command="{Binding ConfirmRemoveCommand}" Classes="danger" />
              <Button Content="Cancel" Command="{Binding CancelRemoveCommand}" Classes="secondary" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
      <Button Grid.Column="0" Content="Import…" Command="{Binding ImportCommand}" IsEnabled="{Binding CanImport}" ToolTip.Tip="Choose a file to import" Classes="primary" />
      <TextBlock Grid.Column="1" Text="Loading…" IsVisible="{Binding IsBusy}" FontSize="12" Foreground="#687385" VerticalAlignment="Center" />
      <Button Grid.Column="2" Content="Close" Command="{Binding CloseCommand}" Classes="secondary" />
    </Grid>
  </Grid>

  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#243447" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#425066" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#9A4B43" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#9A4B43" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
  </Window.Styles>
</Window>
