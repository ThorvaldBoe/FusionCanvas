<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:workspace="clr-namespace:FusionCanvas.App.Workspace"
        xmlns:appWorkspaces="clr-namespace:FusionCanvas.Application.Workspaces;assembly=FusionCanvas.Application"
        x:Class="FusionCanvas.App.Workspace.WorkspaceManagementWindow"
        x:DataType="workspace:WorkspaceManagementViewModel"
        Title="Workspace Management"
        Width="780"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        Background="{DynamicResource ApplicationBackgroundBrush}">
  <Grid ColumnDefinitions="240,*">
    <Border Grid.Column="0"
            Background="{DynamicResource ElevatedSurfaceBrush}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="16">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top"
                    Spacing="8"
                    Margin="0,0,0,16">
          <TextBlock Text="Workspaces"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PrimaryTextBrush}" />
          <Button Content="New workspace"
                  Command="{Binding StartCreateWorkspaceCommand}"
                  Classes="primary" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="12">
            <TextBlock Text="Active"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
            <ItemsControl ItemsSource="{Binding ActiveWorkspaces}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="appWorkspaces:WorkspaceSummary">
                  <Button Content="{Binding Name}"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectWorkspaceCommand}"
                          CommandParameter="{Binding}"
                          Classes="listItem"
                          HorizontalContentAlignment="Left" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock IsVisible="{Binding HasArchivedWorkspaces}"
                       Text="Archived"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,8,0,0" />
            <ItemsControl IsVisible="{Binding HasArchivedWorkspaces}"
                          ItemsSource="{Binding ArchivedWorkspaces}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="appWorkspaces:WorkspaceSummary">
                  <Button Content="{Binding Name}"
                          Command="{Binding $parent[ItemsControl].DataContext.RestoreWorkspaceCommand}"
                          CommandParameter="{Binding}"
                          Classes="listItem"
                          HorizontalContentAlignment="Left" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Margin="18"
            Padding="20"
            Background="{DynamicResource ElevatedSurfaceBrush}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="1">
      <ScrollViewer>
        <StackPanel Spacing="12">
          <TextBlock Text="Workspace Management"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PrimaryTextBrush}" />
          <TextBlock Text="{Binding ErrorMessage}"
                     IsVisible="{Binding HasError}"
                     FontSize="12"
                     Foreground="{DynamicResource DangerTextBrush}" />

          <TextBox Text="{Binding WorkspaceName}"
                   PlaceholderText="Workspace name"
                   Classes="field" />
          <TextBox Text="{Binding Description}"
                   PlaceholderText="Description"
                   Classes="field" />
          <TextBox Text="{Binding Notes}"
                   PlaceholderText="Notes"
                   AcceptsReturn="True"
                   MinHeight="96"
                   Classes="field" />

          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      Margin="0,8,0,0">
            <Button Content="Create"
                    IsVisible="{Binding IsCreatingNewWorkspace}"
                    Command="{Binding CreateWorkspaceCommand}"
                    Classes="primary fixedAction" />
            <Button Content="Save"
                    IsVisible="{Binding !IsCreatingNewWorkspace}"
                    IsEnabled="{Binding CanSaveSelectedWorkspace}"
                    Command="{Binding SaveSelectedWorkspaceCommand}"
                    Classes="primary fixedAction" />
            <Button Content="Archive"
                    IsVisible="{Binding !IsCreatingNewWorkspace}"
                    IsEnabled="{Binding CanArchiveSelectedWorkspace}"
                    Command="{Binding ArchiveSelectedWorkspaceCommand}"
                    Classes="secondary fixedAction" />
            <Button Content="Delete"
                    IsVisible="{Binding !IsCreatingNewWorkspace}"
                    IsEnabled="{Binding CanDeleteSelectedWorkspace}"
                    Command="{Binding RequestDeleteSelectedWorkspaceCommand}"
                    Classes="danger fixedAction" />
          </StackPanel>

          <TextBlock IsVisible="{Binding HasArchivedWorkspaces}"
                     Text="Select an archived workspace in the list to restore it."
                     FontSize="12"
                     Foreground="{DynamicResource SecondaryTextBrush}" />

          <Border IsVisible="{Binding DeleteWarningVisible}"
                  Background="{DynamicResource DangerBackgroundBrush}"
                  BorderBrush="{DynamicResource DangerBorderBrush}"
                  BorderThickness="1"
                  Padding="12"
                  Margin="0,8,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding DeleteWarningMessage}"
                         TextWrapping="Wrap"
                         FontSize="13"
                         Foreground="{DynamicResource DangerTextBrush}" />
              <TextBox Text="{Binding DeleteConfirmationName}"
                        PlaceholderText="Type workspace name"
                        Classes="field" />
              <StackPanel Orientation="Horizontal"
                           Spacing="8">
                <Button Content="Delete permanently"
                        Command="{Binding ConfirmDeleteWorkspaceCommand}"
                        IsEnabled="{Binding CanConfirmDeleteWorkspace}"
                        Classes="danger fixedDanger" />
                <Button Content="Cancel"
                        Command="{Binding CancelDeleteWorkspaceCommand}"
                        Classes="secondary fixedAction" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource CommandForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{DynamicResource ElevatedSurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{DynamicResource DangerStrongBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource CommandForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DangerStrongBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.listItem">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{DynamicResource PanelSurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource StrongTextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SubtleBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox.field">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="8" />
    </Style>
    <Style Selector="Button.fixedAction">
      <Setter Property="Width" Value="104" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.fixedDanger">
      <Setter Property="Width" Value="156" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
  </Window.Styles>
</Window>
