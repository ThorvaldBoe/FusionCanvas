<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:stores="clr-namespace:FusionCanvas.App.Stores"
        xmlns:workflow="clr-namespace:FusionCanvas.Application.Workspace;assembly=FusionCanvas.Application"
        x:Class="FusionCanvas.App.Stores.StoreEditorWindow"
        x:DataType="stores:StoreManagementViewModel"
        Title="Store Editor"
        Width="860"
        Height="620"
        MinWidth="720"
        MinHeight="520"
        Background="#F7F8FA">
  <Grid ColumnDefinitions="260,*"
        RowDefinitions="*">
    <Border Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#D9DEE7"
            BorderThickness="0,0,1,0"
            Padding="16">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top"
                    Spacing="8"
                    Margin="0,0,0,16">
          <TextBlock Text="Stores"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#1E2733" />
          <Button Content="New store"
                  Command="{Binding StartCreateStoreCommand}"
                  Classes="primary" />
        </StackPanel>

        <StackPanel Spacing="12">
          <TextBlock Text="Active"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#687385" />
          <ItemsControl ItemsSource="{Binding EditorActiveStores}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="workflow:StoreSummary">
                <Button Content="{Binding Name}"
                        Command="{Binding $parent[ItemsControl].DataContext.EditStoreCommand}"
                        CommandParameter="{Binding}"
                        Classes="listItem"
                        HorizontalContentAlignment="Left" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock IsVisible="{Binding HasArchivedStores}"
                     Text="Archived"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#687385"
                     Margin="0,8,0,0" />
          <ItemsControl IsVisible="{Binding HasArchivedStores}"
                        ItemsSource="{Binding ArchivedStores}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="workflow:StoreSummary">
                <Button Content="{Binding Name}"
                        Command="{Binding $parent[ItemsControl].DataContext.EditStoreCommand}"
                        CommandParameter="{Binding}"
                        Classes="listItem"
                        HorizontalContentAlignment="Left" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Margin="18"
            Padding="20"
            Background="#FFFFFF"
            BorderBrush="#D9DEE7"
            BorderThickness="1">
      <ScrollViewer>
        <StackPanel Spacing="12">
          <TextBlock Text="Store Management"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#1E2733" />
          <TextBlock Text="{Binding ErrorMessage}"
                     IsVisible="{Binding HasError}"
                     FontSize="12"
                     Foreground="#9A4B43" />
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <Button Content="Basic info"
                    Command="{Binding SelectBasicInfoTabCommand}"
                    Classes="tabButton"
                    Classes.selected="{Binding IsBasicInfoTabSelected}" />
            <Button Content="Niches"
                    Command="{Binding SelectNichesTabCommand}"
                    Classes="tabButton"
                    Classes.selected="{Binding IsNichesTabSelected}" />
            <Button Content="Tags"
                    Command="{Binding SelectTagsTabCommand}"
                    Classes="tabButton"
                    Classes.selected="{Binding IsTagsTabSelected}" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsBasicInfoTabSelected}"
                      Spacing="12">
            <TextBlock Text="Basic info"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#243447" />
            <TextBox x:Name="StoreNameTextBox"
                     Text="{Binding NewStoreName}"
                     PlaceholderText="Store name"
                     Classes="field" />
            <TextBox Text="{Binding Description}"
                     PlaceholderText="Description"
                     Classes="field" />
            <TextBox Text="{Binding Notes}"
                     PlaceholderText="Notes"
                     AcceptsReturn="True"
                     MinHeight="84"
                     Classes="field" />
            <TextBox Text="{Binding TargetMarket}"
                     PlaceholderText="Target market"
                     Classes="field" />
            <TextBox Text="{Binding BrandDirection}"
                     PlaceholderText="Brand direction"
                     Classes="field" />
            <TextBox Text="{Binding PlanningContext}"
                     PlaceholderText="Planning context"
                     Classes="field" />

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,8,0,0">
              <Button Content="Save"
                      Command="{Binding SaveSelectedStoreCommand}"
                      IsEnabled="{Binding CanSaveSelectedStore}"
                      Classes="primary fixedAction" />
              <Button Content="Archive"
                      Command="{Binding ArchiveSelectedStoreCommand}"
                      IsEnabled="{Binding CanArchiveSelectedStore}"
                      Classes="secondary fixedAction" />
              <Button Content="Delete"
                      Command="{Binding RequestDeleteSelectedStoreCommand}"
                      IsEnabled="{Binding CanDeleteSelectedStore}"
                      Classes="danger fixedAction" />
            </StackPanel>

            <Button Content="Restore selected archived store"
                    IsVisible="{Binding CanRestoreSelectedStore}"
                    Command="{Binding RestoreStoreCommand}"
                    CommandParameter="{Binding SelectedStore}"
                    Classes="secondary restoreAction" />
          </StackPanel>

          <Grid IsVisible="{Binding IsNichesTabSelected}"
                ColumnDefinitions="220,*"
                ColumnSpacing="16">
            <StackPanel Grid.Column="0"
                        Spacing="10">
              <Button Content="New niche"
                      Command="{Binding StartCreateNicheCommand}"
                      Classes="primary" />
              <TextBlock Text="Active niches"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#687385" />
              <TextBlock Text="No active niches"
                         IsVisible="{Binding !HasActiveNiches}"
                         FontSize="12"
                         Foreground="#687385" />
              <ItemsControl ItemsSource="{Binding EditorActiveNiches}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="workflow:NicheSummary">
                    <Button Content="{Binding Name}"
                            Command="{Binding $parent[ItemsControl].DataContext.EditNicheCommand}"
                            CommandParameter="{Binding}"
                            Classes="listItem"
                            HorizontalContentAlignment="Left" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock IsVisible="{Binding HasArchivedNiches}"
                         Text="Archived niches"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#687385"
                         Margin="0,8,0,0" />
              <ItemsControl IsVisible="{Binding HasArchivedNiches}"
                            ItemsSource="{Binding ArchivedNiches}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="workflow:NicheSummary">
                    <Button Content="{Binding Name}"
                            Command="{Binding $parent[ItemsControl].DataContext.EditNicheCommand}"
                            CommandParameter="{Binding}"
                            Classes="listItem"
                            HorizontalContentAlignment="Left" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Spacing="10">
              <TextBlock Text="Niche details"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="#243447" />
              <TextBox Text="{Binding NicheName}"
                       PlaceholderText="Niche name"
                       Classes="field" />
              <TextBox Text="{Binding NicheDescription}"
                       PlaceholderText="Description"
                       Classes="field" />
              <TextBox Text="{Binding NicheAudience}"
                       PlaceholderText="Audience"
                       Classes="field" />
              <TextBox Text="{Binding NicheHumorStyle}"
                       PlaceholderText="Humor style"
                       Classes="field" />
              <TextBox Text="{Binding NicheVisualStyleGuidance}"
                       PlaceholderText="Visual style guidance"
                       Classes="field" />
              <TextBox Text="{Binding NicheConstraints}"
                       PlaceholderText="Constraints"
                       Classes="field" />
              <TextBox Text="{Binding NicheRisks}"
                       PlaceholderText="Risks"
                       Classes="field" />
              <TextBox Text="{Binding NicheResearchNotes}"
                       PlaceholderText="Research notes"
                       AcceptsReturn="True"
                       MinHeight="70"
                       Classes="field" />
              <TextBox Text="{Binding NicheNotes}"
                       PlaceholderText="Notes"
                       AcceptsReturn="True"
                       MinHeight="70"
                       Classes="field" />

              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          Margin="0,8,0,0">
                <Button Content="Save"
                        Command="{Binding SaveSelectedNicheCommand}"
                        IsEnabled="{Binding CanSaveSelectedNiche}"
                        Classes="primary fixedAction" />
                <Button Content="Archive"
                        Command="{Binding ArchiveSelectedNicheCommand}"
                        IsEnabled="{Binding CanArchiveSelectedNiche}"
                        Classes="secondary fixedAction" />
                <Button Content="Delete"
                        Command="{Binding RequestDeleteSelectedNicheCommand}"
                        IsEnabled="{Binding CanDeleteSelectedNiche}"
                        Classes="danger fixedAction" />
              </StackPanel>

              <Button Content="Restore selected archived niche"
                      IsVisible="{Binding CanRestoreSelectedNiche}"
                      Command="{Binding RestoreNicheCommand}"
                      CommandParameter="{Binding SelectedNiche}"
                      Classes="secondary restoreAction" />
            </StackPanel>
          </Grid>

          <Grid IsVisible="{Binding IsTagsTabSelected}"
                ColumnDefinitions="220,*"
                ColumnSpacing="16">
            <StackPanel Grid.Column="0"
                        Spacing="10">
              <Button Content="New tag"
                      Command="{Binding StartCreateTagCommand}"
                      Classes="primary" />
              <TextBlock Text="Active tags"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#687385" />
              <TextBlock Text="No active tags"
                         IsVisible="{Binding !HasActiveTags}"
                         FontSize="12"
                         Foreground="#687385" />
              <ItemsControl ItemsSource="{Binding EditorActiveTags}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="workflow:TagSummary">
                    <Button Content="{Binding Name}"
                            Command="{Binding $parent[ItemsControl].DataContext.EditTagCommand}"
                            CommandParameter="{Binding}"
                            Classes="listItem"
                            HorizontalContentAlignment="Left" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock IsVisible="{Binding HasArchivedTags}"
                         Text="Archived tags"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#687385"
                         Margin="0,8,0,0" />
              <ItemsControl IsVisible="{Binding HasArchivedTags}"
                            ItemsSource="{Binding ArchivedTags}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="workflow:TagSummary">
                    <Button Content="{Binding Name}"
                            Command="{Binding $parent[ItemsControl].DataContext.EditTagCommand}"
                            CommandParameter="{Binding}"
                            Classes="listItem"
                            HorizontalContentAlignment="Left" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Spacing="10">
              <TextBlock Text="Tag details"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="#243447" />
              <TextBox Text="{Binding TagName}"
                       PlaceholderText="Tag name"
                       Classes="field" />
              <StackPanel Spacing="4">
                <TextBlock Text="Color"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#687385" />
                <TextBox Text="{Binding TagColor}"
                         PlaceholderText="#RRGGBB (optional)"
                         Classes="field" />
              </StackPanel>
              <TextBox Text="{Binding TagDescription}"
                       PlaceholderText="Description"
                       Classes="field" />

              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          Margin="0,8,0,0">
                <Button Content="Save"
                        Command="{Binding SaveSelectedTagCommand}"
                        IsEnabled="{Binding CanSaveSelectedTag}"
                        Classes="primary fixedAction" />
                <Button Content="Archive"
                        Command="{Binding ArchiveSelectedTagCommand}"
                        IsEnabled="{Binding CanArchiveSelectedTag}"
                        Classes="secondary fixedAction" />
                <Button Content="Delete"
                        Command="{Binding RequestDeleteSelectedTagCommand}"
                        IsEnabled="{Binding CanDeleteSelectedTag}"
                        Classes="danger fixedAction" />
              </StackPanel>

              <Button Content="Restore selected archived tag"
                      IsVisible="{Binding CanRestoreSelectedTag}"
                      Command="{Binding RestoreTagCommand}"
                      CommandParameter="{Binding SelectedTag}"
                      Classes="secondary restoreAction" />
            </StackPanel>
          </Grid>

          <Border IsVisible="{Binding TagDeleteWarningVisible}"
                  Background="#FFF7F2"
                  BorderBrush="#DFA481"
                  BorderThickness="1"
                  Padding="12"
                  Margin="0,8,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding TagDeleteWarningMessage}"
                         FontSize="13"
                         Foreground="#6B3527" />
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <Button Content="Delete permanently"
                        Command="{Binding ConfirmDeleteTagCommand}"
                        Classes="danger fixedDanger" />
                <Button Content="Cancel"
                        Command="{Binding CancelDeleteTagCommand}"
                        Classes="secondary fixedAction" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border IsVisible="{Binding DeleteWarningVisible}"
                  Background="#FFF7F2"
                  BorderBrush="#DFA481"
                  BorderThickness="1"
                  Padding="12"
                  Margin="0,8,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding DeleteWarningMessage}"
                         FontSize="13"
                         Foreground="#6B3527" />
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <Button Content="Delete permanently"
                        Command="{Binding ConfirmDeleteStoreCommand}"
                        Classes="danger fixedDanger" />
                <Button Content="Cancel"
                        Command="{Binding CancelDeleteStoreCommand}"
                        Classes="secondary fixedAction" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border IsVisible="{Binding NicheDeleteWarningVisible}"
                  Background="#FFF7F2"
                  BorderBrush="#DFA481"
                  BorderThickness="1"
                  Padding="12"
                  Margin="0,8,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding NicheDeleteWarningMessage}"
                         FontSize="13"
                         Foreground="#6B3527" />
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <Button Content="Delete permanently"
                        Command="{Binding ConfirmDeleteNicheCommand}"
                        Classes="danger fixedDanger" />
                <Button Content="Cancel"
                        Command="{Binding CancelDeleteNicheCommand}"
                        Classes="secondary fixedAction" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border IsVisible="{Binding DiscardChangesPromptVisible}"
                  Background="#FFF8D9"
                  BorderBrush="#D4B14F"
                  BorderThickness="1"
                  Padding="12"
                  Margin="0,8,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding DiscardChangesMessage}"
                         FontSize="13"
                         Foreground="#5F4A12" />
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <Button Content="Discard changes"
                        Command="{Binding ConfirmDiscardChangesCommand}"
                        Classes="danger fixedDanger" />
                <Button Content="Keep editing"
                        Command="{Binding KeepEditingCommand}"
                        Classes="secondary fixedDanger" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#243447" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#425066" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#8F3D31" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#8F3D31" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.fixedAction">
      <Setter Property="Width" Value="104" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.fixedDanger">
      <Setter Property="Width" Value="156" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.restoreAction">
      <Setter Property="Width" Value="220" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.listItem">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#F7F8FA" />
      <Setter Property="Foreground" Value="#243447" />
      <Setter Property="BorderBrush" Value="#E1E5EA" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.tabButton">
      <Setter Property="Width" Value="116" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#425066" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.tabButton.selected">
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#243447" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBox.field">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#243447" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
  </Window.Styles>
</Window>
