<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:groups="clr-namespace:FusionCanvas.App.Groups"
        xmlns:workflow="clr-namespace:FusionCanvas.Application.Workspace;assembly=FusionCanvas.Application"
        x:Class="FusionCanvas.App.Groups.GroupEditorWindow"
        x:DataType="groups:GroupManagementViewModel"
        Title="Edit Group Properties"
        Width="900"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        Background="#F7F8FA">
  <Grid ColumnDefinitions="280,*">
    <Border Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#D9DEE7"
            BorderThickness="0,0,1,0"
            Padding="16">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
          <TextBlock Text="Group properties" FontSize="18" FontWeight="SemiBold" Foreground="#1E2733" />
          <TextBlock Text="Create and rename groups directly in the workspace tree." TextWrapping="Wrap" FontSize="11" Foreground="#687385" />
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10">
            <TextBlock Text="Active" FontSize="12" FontWeight="SemiBold" Foreground="#687385" />
            <TextBlock Text="No active groups yet. Create a lightweight planning container."
                       IsVisible="{Binding ShowsEmptyState}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#687385" />
            <ItemsControl x:Name="ActiveGroupsList" ItemsSource="{Binding ActiveGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="workflow:GroupSummary">
                  <Button Content="{Binding DisplayPath}"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectGroupCommand}"
                          CommandParameter="{Binding}"
                          Classes="listItem"
                          HorizontalContentAlignment="Left" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="Archived"
                       IsVisible="{Binding HasArchivedGroups}"
                       Margin="0,10,0,0"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#687385" />
            <ItemsControl ItemsSource="{Binding ArchivedGroups}" IsVisible="{Binding HasArchivedGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="workflow:GroupSummary">
                  <Button Content="{Binding DisplayPath}"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectGroupCommand}"
                          CommandParameter="{Binding}"
                          Classes="archivedItem"
                          HorizontalContentAlignment="Left" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Margin="18"
            Padding="20"
            Background="#FFFFFF"
            BorderBrush="#D9DEE7"
            BorderThickness="1">
      <Grid>
        <ScrollViewer>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="3">
                <TextBlock Text="Edit properties" FontSize="22" FontWeight="SemiBold" Foreground="#1E2733" />
                <TextBlock Text="Edit detailed context here; everyday structure stays in the workspace tree."
                           FontSize="12" Foreground="#687385" />
              </StackPanel>
              <Button Grid.Column="1" Content="Close" Command="{Binding CloseCommand}" Classes="secondary fixedAction" />
            </Grid>

            <TextBlock Text="Loading group data..." IsVisible="{Binding IsBusy}" FontSize="12" Foreground="#687385" />
            <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextWrapping="Wrap" FontSize="12" Foreground="#9A4B43" />

            <StackPanel IsVisible="{Binding HasSelection}" Spacing="12">
              <TextBox x:Name="GroupNameTextBox"
                       Text="{Binding Name}"
                       PlaceholderText="Group name"
                       IsEnabled="{Binding !IsBusy}"
                       Classes="field" />
              <TextBox Text="{Binding Description}"
                       PlaceholderText="Description or purpose"
                       IsEnabled="{Binding !IsBusy}"
                       Classes="field" />
              <TextBox Text="{Binding Notes}"
                       PlaceholderText="Notes and working context"
                       AcceptsReturn="True"
                       MinHeight="110"
                       IsEnabled="{Binding !IsBusy}"
                       Classes="field" />

              <TextBlock Text="Location" FontSize="12" FontWeight="SemiBold" Foreground="#425066" />
              <ComboBox ItemsSource="{Binding Destinations}"
                        SelectedItem="{Binding SelectedDestination}"
                        IsEnabled="{Binding !IsBusy}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="workflow:GroupDestination">
                    <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}" Classes="primary fixedAction" />
                <Button Content="Move" Command="{Binding MoveCommand}" IsEnabled="{Binding CanMove}" Classes="secondary fixedAction" />
                <Button Content="Archive" Command="{Binding RequestArchiveCommand}" IsEnabled="{Binding CanArchive}" Classes="danger fixedAction" />
                <Button Content="Restore" Command="{Binding RestoreCommand}" CommandParameter="{Binding SelectedGroup}" IsVisible="{Binding CanRestore}" Classes="secondary fixedAction" />
              </StackPanel>
            </StackPanel>

            <Border IsVisible="{Binding !HasSelection}" Padding="18" Background="#F7F8FA" BorderBrush="#D9DEE7" BorderThickness="1">
              <TextBlock Text="Select a group to review it, or start a new group draft."
                         TextWrapping="Wrap" Foreground="#687385" />
            </Border>
          </StackPanel>
        </ScrollViewer>

        <Border IsVisible="{Binding DiscardPromptVisible}" Background="#F2FFFFFF" Padding="18">
          <Border Width="420" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="18" Background="#FFFFFF" BorderBrush="#D9DEE7" BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Unsaved group changes" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="Save your edits, discard them, or keep editing before continuing." TextWrapping="Wrap" Foreground="#687385" />
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Save" Command="{Binding SaveAndContinueCommand}" Classes="primary fixedAction" />
                <Button Content="Discard" Command="{Binding DiscardAndContinueCommand}" Classes="danger fixedAction" />
                <Button Content="Keep editing" Command="{Binding KeepEditingCommand}" Classes="secondary fixedAction" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Border>

        <Border IsVisible="{Binding ArchiveWarningVisible}" Background="#F2FFFFFF" Padding="18">
          <Border Width="420" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="18" Background="#FFFFFF" BorderBrush="#D9DEE7" BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Archive this group?" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="The group and its subtree will leave active navigation, but all child work and context remain preserved." TextWrapping="Wrap" Foreground="#687385" />
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Archive" Command="{Binding ConfirmArchiveCommand}" Classes="danger fixedAction" />
                <Button Content="Cancel" Command="{Binding CancelArchiveCommand}" Classes="secondary fixedAction" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Border>
      </Grid>
    </Border>
  </Grid>

  <Window.Styles>
    <Style Selector="TextBox.field">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#243447" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#425066" />
      <Setter Property="BorderBrush" Value="#D9DEE7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#9A4B43" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.fixedAction">
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.listItem, Button.archivedItem">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Margin" Value="0,0,0,5" />
      <Setter Property="Background" Value="#F7F8FA" />
      <Setter Property="Foreground" Value="#243447" />
      <Setter Property="BorderBrush" Value="#E1E5EA" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.archivedItem">
      <Setter Property="Foreground" Value="#687385" />
      <Setter Property="Background" Value="#F1F3F6" />
    </Style>
  </Window.Styles>
</Window>
