<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:listings="using:FusionCanvas.App.Listings"
        xmlns:workspace="using:FusionCanvas.Application.Workspace"
        x:Class="FusionCanvas.App.Listings.ListingEditorWindow"
        x:DataType="listings:ListingManagementViewModel"
        Title="Listing properties" Width="560" Height="620"
        MinWidth="460" MinHeight="480" CanResize="True">
  <Grid RowDefinitions="Auto,*,Auto" Margin="20">
    <StackPanel Spacing="4">
      <TextBlock Text="Listing properties" FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="{Binding SelectedListing.DisplayPath}" Opacity="0.65" TextWrapping="Wrap" />
    </StackPanel>
    <ScrollViewer Grid.Row="1" Margin="0,18,0,18">
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
          <StackPanel Spacing="4">
            <TextBlock Text="Active" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ActiveListings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="workspace:ListingSummary">
                  <Button Content="{Binding Name}"
                          HorizontalContentAlignment="Left"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectListingCommand}"
                          CommandParameter="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Archived or unavailable" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ArchivedListings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="workspace:ListingSummary">
                  <Button Content="{Binding Name}"
                          HorizontalContentAlignment="Left"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectListingCommand}"
                          CommandParameter="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Grid>
        <TextBlock Text="{Binding SelectedListing.Name}" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="Description" />
        <TextBox Text="{Binding Description}" AcceptsReturn="True" MinHeight="90" TabIndex="0" />
        <TextBlock Text="Notes" />
        <TextBox Text="{Binding Notes}" AcceptsReturn="True" MinHeight="110" TabIndex="1" />
        <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" Foreground="#B42318" TextWrapping="Wrap" />
        <Border IsVisible="{Binding DiscardPromptVisible}" Padding="12" Background="#FFF4E5" CornerRadius="6">
          <StackPanel Spacing="8">
            <TextBlock Text="Save changes before closing?" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Save" Command="{Binding SaveAndCloseCommand}" />
              <Button Content="Discard" Command="{Binding DiscardAndCloseCommand}" />
              <Button Content="Cancel" Command="{Binding KeepEditingCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
        <Border IsVisible="{Binding DeleteConfirmationVisible}" Padding="12" Background="#FEECEB" CornerRadius="6">
          <StackPanel Spacing="8">
            <TextBlock Text="Permanently delete this listing? Connected creative records will block deletion." TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Delete permanently" Command="{Binding ConfirmDeleteCommand}" />
              <Button Content="Cancel" Command="{Binding CancelDeleteCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
      <Button Content="Archive" Command="{Binding ArchiveCommand}" IsEnabled="{Binding CanArchive}" ToolTip.Tip="Archive listing" />
      <Button Grid.Column="1" Content="Restore" Command="{Binding RestoreCommand}" IsEnabled="{Binding CanRestore}" ToolTip.Tip="Restore listing" />
      <Button Grid.Column="2" Content="Delete…" Command="{Binding RequestDeleteCommand}" IsEnabled="{Binding CanDelete}" ToolTip.Tip="Permanently delete listing" />
      <Button Grid.Column="4" Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}" />
      <Button Grid.Column="5" Content="Close" Command="{Binding CloseCommand}" />
    </Grid>
  </Grid>
</Window>
