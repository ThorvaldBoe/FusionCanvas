<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:listings="using:FusionCanvas.App.Listings"
        xmlns:workspace="using:FusionCanvas.Application.Workspace"
        x:Class="FusionCanvas.App.Listings.ListingEditorWindow"
        x:DataType="listings:ListingManagementViewModel"
        Title="Listing properties" Width="560" Height="620"
        MinWidth="460" MinHeight="480" CanResize="True">
  <Grid RowDefinitions="Auto,*,Auto" Margin="20">
    <StackPanel Spacing="4">
      <TextBlock Text="Listing properties" FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="{Binding SelectedListing.DisplayPath}" Opacity="0.65" TextWrapping="Wrap" />
    </StackPanel>
    <ScrollViewer Grid.Row="1" Margin="0,18,0,18">
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
          <StackPanel Spacing="4">
            <TextBlock Text="Active" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ActiveListings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="workspace:ListingSummary">
                  <Button Content="{Binding Name}"
                          HorizontalContentAlignment="Left"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectListingCommand}"
                          CommandParameter="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Archived or unavailable" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ArchivedListings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="workspace:ListingSummary">
                  <Button Content="{Binding Name}"
                          HorizontalContentAlignment="Left"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectListingCommand}"
                          CommandParameter="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Grid>
        <TextBlock Text="{Binding SelectedListing.Name}" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="Tags" FontWeight="SemiBold" />
        <StackPanel IsVisible="{Binding !CanEditTags}" Spacing="4">
          <TextBlock Text="Restore the listing or its parent topic before editing tags." Opacity="0.65" TextWrapping="Wrap" FontSize="11" />
        </StackPanel>
        <StackPanel IsVisible="{Binding CanEditTags}" Spacing="6">
          <ItemsControl ItemsSource="{Binding AppliedTags}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="workspace:TagSummary">
                <Border Margin="0,0,4,4"
                        Padding="8,2"
                        CornerRadius="8"
                        Background="{Binding Color, Converter={x:Static listings:TagEditorBrushConverter.Background}, FallbackValue='#F0F2F5'}"
                        BorderBrush="{Binding Color, Converter={x:Static listings:TagEditorBrushConverter.Border}, FallbackValue='#D9DEE7'}"
                        BorderThickness="1">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}"
                               Foreground="{Binding Color, Converter={x:Static listings:TagEditorBrushConverter.Foreground}, FallbackValue='#243447'}"
                               FontSize="12" />
                    <Button Content="✕"
                            Padding="0"
                            Width="18" Height="18"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding Color, Converter={x:Static listings:TagEditorBrushConverter.Foreground}, FallbackValue='#425066'}"
                            Command="{Binding $parent[ItemsControl].((listings:ListingManagementViewModel)DataContext).RemoveTagCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="Remove tag from listing" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBox Text="{Binding TagInput}"
                   PlaceholderText="Add a tag…"
                   IsEnabled="{Binding !IsBusyTags}"
                   MinHeight="32"
                   KeyDown="OnTagInputKeyDown" />
          <ItemsControl ItemsSource="{Binding SuggestedTags}" IsVisible="{Binding HasSuggestions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="workspace:TagSummary">
                <Button Content="{Binding Name}"
                        Command="{Binding $parent[ItemsControl].((listings:ListingManagementViewModel)DataContext).ApplyTagSuggestionCommand}"
                        CommandParameter="{Binding}"
                        HorizontalContentAlignment="Left"
                        Margin="0,0,0,2"
                        Padding="8,4"
                        Background="{Binding Color, Converter={x:Static listings:TagEditorBrushConverter.Background}, FallbackValue='#F7F8FA'}"
                        Foreground="{Binding Color, Converter={x:Static listings:TagEditorBrushConverter.Foreground}, FallbackValue='#243447'}"
                        BorderBrush="{Binding Color, Converter={x:Static listings:TagEditorBrushConverter.Border}, FallbackValue='#E1E5EA'}"
                        ToolTip.Tip="Apply this tag" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="{Binding TagErrorMessage}" IsVisible="{Binding HasTagError}" Foreground="#B42318" FontSize="11" TextWrapping="Wrap" />
        </StackPanel>
        <TextBlock Text="Description" />
        <TextBox Text="{Binding Description}" AcceptsReturn="True" MinHeight="90" TabIndex="0" />
        <TextBlock Text="Notes" />
        <TextBox Text="{Binding Notes}" AcceptsReturn="True" MinHeight="110" TabIndex="1" />
        <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" Foreground="#B42318" TextWrapping="Wrap" />
        <Border IsVisible="{Binding DiscardPromptVisible}" Padding="12" Background="#FFF4E5" CornerRadius="6">
          <StackPanel Spacing="8">
            <TextBlock Text="Save changes before closing?" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Save" Command="{Binding SaveAndCloseCommand}" />
              <Button Content="Discard" Command="{Binding DiscardAndCloseCommand}" />
              <Button Content="Cancel" Command="{Binding KeepEditingCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
        <Border IsVisible="{Binding DeleteConfirmationVisible}" Padding="12" Background="#FEECEB" CornerRadius="6">
          <StackPanel Spacing="8">
            <TextBlock Text="Permanently delete this listing? Connected creative records will block deletion." TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Delete permanently" Command="{Binding ConfirmDeleteCommand}" />
              <Button Content="Cancel" Command="{Binding CancelDeleteCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
      <Button Content="Archive" Command="{Binding ArchiveCommand}" IsEnabled="{Binding CanArchive}" ToolTip.Tip="Archive listing" />
      <Button Grid.Column="1" Content="Restore" Command="{Binding RestoreCommand}" IsEnabled="{Binding CanRestore}" ToolTip.Tip="Restore listing" />
      <Button Grid.Column="2" Content="Delete…" Command="{Binding RequestDeleteCommand}" IsEnabled="{Binding CanDelete}" ToolTip.Tip="Permanently delete listing" />
      <Button Grid.Column="4" Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}" />
      <Button Grid.Column="5" Content="Close" Command="{Binding CloseCommand}" />
    </Grid>
  </Grid>
</Window>
